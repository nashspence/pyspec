{
  "entry_point_guards": {
    "entry_point.api.project.create": {
      "policy": "policy.project.create"
    },
    "entry_point.api.project.list": {
      "policy": "policy.project.list"
    },
    "entry_point.cli.project.approve": {
      "policy": "policy.project.approve"
    }
  },
  "operation_guards": {
    "operation.project.approve": {
      "policy": "policy.project.approve"
    },
    "operation.project.archive": {
      "policy": "policy.project.archive"
    },
    "operation.project.create": {
      "policy": "policy.project.create"
    },
    "operation.project.list": {
      "policy": "policy.project.list"
    },
    "operation.project.read": {
      "policy": "policy.project.read"
    },
    "operation.project.send_approval_notice": {
      "policy": "policy.project.send_approval_notice"
    },
    "operation.project.submit": {
      "policy": "policy.project.submit"
    }
  },
  "policies": {
    "policy.project.approve": {
      "actions": [
        {
          "operation": "operation.project.approve"
        }
      ],
      "conditions": [
        {
          "resource_state": {
            "equals": "submitted",
            "field": "status",
            "model": "Project"
          }
        }
      ],
      "effect": "allow",
      "rationale": "Reviewers can approve submitted dispatch projects.",
      "resources": [
        {
          "model": "Project"
        }
      ],
      "subjects": [
        {
          "kind": "actor",
          "source": "$input.approved_by"
        }
      ]
    },
    "policy.project.archive": {
      "actions": [
        {
          "operation": "operation.project.archive"
        }
      ],
      "conditions": [
        {
          "resource_state": {
            "equals": "approved",
            "field": "status",
            "model": "Project"
          }
        }
      ],
      "effect": "allow",
      "rationale": "Approved dispatch projects can be archived.",
      "resources": [
        {
          "model": "Project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    },
    "policy.project.create": {
      "actions": [
        {
          "operation": "operation.project.create"
        }
      ],
      "conditions": [
        {
          "always": true
        }
      ],
      "effect": "allow",
      "rationale": "Members can create a new dispatch project.",
      "resources": [
        {
          "model": "Project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    },
    "policy.project.list": {
      "actions": [
        {
          "operation": "operation.project.list"
        }
      ],
      "conditions": [
        {
          "always": true
        }
      ],
      "effect": "allow",
      "rationale": "The board requires a project list query scoped by workspace.",
      "resources": [
        {
          "model": "Project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    },
    "policy.project.read": {
      "actions": [
        {
          "operation": "operation.project.read"
        }
      ],
      "conditions": [
        {
          "always": true
        }
      ],
      "effect": "allow",
      "rationale": "The detail state machine loads the selected project by id.",
      "resources": [
        {
          "model": "Project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    },
    "policy.project.send_approval_notice": {
      "actions": [
        {
          "operation": "operation.project.send_approval_notice"
        }
      ],
      "conditions": [
        {
          "always": true
        }
      ],
      "effect": "allow",
      "rationale": "Approval triggers a notification command for downstream coordination.",
      "resources": [
        {
          "operation": "operation.project.send_approval_notice"
        }
      ],
      "subjects": [
        {
          "kind": "actor",
          "source": "$input.approved_by"
        }
      ]
    },
    "policy.project.submit": {
      "actions": [
        {
          "operation": "operation.project.submit"
        }
      ],
      "conditions": [
        {
          "resource_state": {
            "equals": "draft",
            "field": "status",
            "model": "Project"
          }
        }
      ],
      "effect": "allow",
      "rationale": "Draft dispatch projects can be submitted for review.",
      "resources": [
        {
          "model": "Project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    }
  },
  "project": "project_dispatch_board"
}
