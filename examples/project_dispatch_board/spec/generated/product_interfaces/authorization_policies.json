{
  "authorization_policies": {
    "authorization_policy.project.approve": {
      "conditions": [
        {
          "model_state": {
            "equals": "submitted",
            "field": "status",
            "model": "Project"
          }
        }
      ],
      "effect": "allow",
      "rationale": "Reviewers can approve submitted dispatch projects.",
      "subjects": [
        {
          "kind": "actor",
          "source": "$input.approved_by"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.approve"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.archive": {
      "conditions": [
        {
          "model_state": {
            "equals": "approved",
            "field": "status",
            "model": "Project"
          }
        }
      ],
      "effect": "allow",
      "rationale": "Approved dispatch projects can be archived.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.archive"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.create": {
      "conditions": [
        {
          "unconditional": true
        }
      ],
      "effect": "allow",
      "rationale": "Members can create a new dispatch project.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.create"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.list": {
      "conditions": [
        {
          "unconditional": true
        }
      ],
      "effect": "allow",
      "rationale": "The board requires a project list query scoped by workspace.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.list"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.read": {
      "conditions": [
        {
          "unconditional": true
        }
      ],
      "effect": "allow",
      "rationale": "The detail state machine loads the selected project by id.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.read"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.send_approval_notice": {
      "conditions": [
        {
          "unconditional": true
        }
      ],
      "effect": "allow",
      "rationale": "Approval triggers a notification command for downstream coordination.",
      "subjects": [
        {
          "kind": "actor",
          "source": "$input.approved_by"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.send_approval_notice"
        }
      ]
    },
    "authorization_policy.project.submit": {
      "conditions": [
        {
          "model_state": {
            "equals": "draft",
            "field": "status",
            "model": "Project"
          }
        }
      ],
      "effect": "allow",
      "rationale": "Draft dispatch projects can be submitted for review.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.submit"
        },
        {
          "model": "Project"
        }
      ]
    }
  },
  "entry_point_authorization_policies": {
    "entry_point.api.project.create": "authorization_policy.project.create",
    "entry_point.api.project.list": "authorization_policy.project.list",
    "entry_point.cli.project.approve": "authorization_policy.project.approve"
  },
  "operation_authorization_policies": {
    "operation.project.approve": "authorization_policy.project.approve",
    "operation.project.archive": "authorization_policy.project.archive",
    "operation.project.create": "authorization_policy.project.create",
    "operation.project.list": "authorization_policy.project.list",
    "operation.project.read": "authorization_policy.project.read",
    "operation.project.send_approval_notice": "authorization_policy.project.send_approval_notice",
    "operation.project.submit": "authorization_policy.project.submit"
  },
  "project": "project_dispatch_board"
}
