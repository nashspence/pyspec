{
  "action_authorizations": {
    "application_action.project.approve": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.reviewer"
    },
    "application_action.project.archive": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.reviewer"
    },
    "application_action.project.create": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.member"
    },
    "application_action.project.list": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.member"
    },
    "application_action.project.read": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.member"
    },
    "application_action.project.send_approval_notice": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.reviewer"
    },
    "application_action.project.submit": {
      "access_denied_as": "access_denied",
      "authentication_required_as": "authentication_required",
      "policy": "authorization_policy.project.member"
    }
  },
  "authorization_policies": {
    "authorization_policy.project.member": {
      "conditions": [
        {
          "subject_has_role": "member"
        }
      ],
      "effect": "permit",
      "rationale": "Workspace members may create, read, list, and submit dispatch projects.",
      "resources": [
        {
          "action": "application_action.project.create"
        },
        {
          "action": "application_action.project.list"
        },
        {
          "action": "application_action.project.read"
        },
        {
          "action": "application_action.project.submit"
        },
        {
          "entity_type": "entity_type.project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    },
    "authorization_policy.project.reviewer": {
      "conditions": [
        {
          "subject_has_role": "reviewer"
        }
      ],
      "effect": "permit",
      "rationale": "Reviewers may approve, archive, and send approval notices for dispatch projects.",
      "resources": [
        {
          "action": "application_action.project.approve"
        },
        {
          "action": "application_action.project.archive"
        },
        {
          "action": "application_action.project.send_approval_notice"
        },
        {
          "entity_type": "entity_type.project"
        }
      ],
      "subjects": [
        {
          "kind": "actor"
        }
      ]
    }
  },
  "entry_point_authorization_policies": {
    "entry_point.api.project.approve": "authorization_policy.project.reviewer",
    "entry_point.api.project.create": "authorization_policy.project.member",
    "entry_point.api.project.list": "authorization_policy.project.member"
  },
  "project": "project_dispatch_board"
}
