{
  "authorization_policies": {
    "authorization_policy.project.approve": {
      "conditions": [
        {
          "subject_has_role": "reviewer"
        }
      ],
      "effect": "allow",
      "rationale": "Reviewers may approve submitted dispatch projects.",
      "subjects": [
        {
          "kind": "actor",
          "source": "$input.approved_by"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.approve"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.archive": {
      "conditions": [
        {
          "subject_has_role": "reviewer"
        }
      ],
      "effect": "allow",
      "rationale": "Reviewers may archive approved dispatch projects.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.archive"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.create": {
      "conditions": [
        {
          "subject_has_role": "member"
        }
      ],
      "effect": "allow",
      "rationale": "Workspace members may create dispatch projects.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.create"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.list": {
      "conditions": [
        {
          "subject_has_role": "member"
        }
      ],
      "effect": "allow",
      "rationale": "Workspace members may list dispatch projects.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.list"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.read": {
      "conditions": [
        {
          "subject_has_role": "member"
        }
      ],
      "effect": "allow",
      "rationale": "Workspace members may read dispatch project details.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.read"
        },
        {
          "model": "Project"
        }
      ]
    },
    "authorization_policy.project.send_approval_notice": {
      "conditions": [
        {
          "subject_has_role": "reviewer"
        }
      ],
      "effect": "allow",
      "rationale": "Approval notice dispatch runs on behalf of the approving reviewer.",
      "subjects": [
        {
          "kind": "actor",
          "source": "$input.approved_by"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.send_approval_notice"
        }
      ]
    },
    "authorization_policy.project.submit": {
      "conditions": [
        {
          "subject_has_role": "member"
        }
      ],
      "effect": "allow",
      "rationale": "Workspace members may submit draft dispatch projects.",
      "subjects": [
        {
          "kind": "actor"
        }
      ],
      "targets": [
        {
          "operation": "operation.project.submit"
        },
        {
          "model": "Project"
        }
      ]
    }
  },
  "entry_point_authorization_policies": {
    "entry_point.api.project.approve": "authorization_policy.project.approve",
    "entry_point.api.project.create": "authorization_policy.project.create",
    "entry_point.api.project.list": "authorization_policy.project.list"
  },
  "operation_authorizations": {
    "operation.project.approve": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.approve",
      "unauthenticated_as": "unauthenticated"
    },
    "operation.project.archive": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.archive",
      "unauthenticated_as": "unauthenticated"
    },
    "operation.project.create": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.create",
      "unauthenticated_as": "unauthenticated"
    },
    "operation.project.list": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.list",
      "unauthenticated_as": "unauthenticated"
    },
    "operation.project.read": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.read",
      "unauthenticated_as": "unauthenticated"
    },
    "operation.project.send_approval_notice": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.send_approval_notice",
      "unauthenticated_as": "unauthenticated"
    },
    "operation.project.submit": {
      "forbidden_as": "forbidden",
      "policy": "authorization_policy.project.submit",
      "unauthenticated_as": "unauthenticated"
    }
  },
  "project": "project_dispatch_board"
