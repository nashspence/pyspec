            "from": "empty",
            "on": "message.project.selection_changed",
            "to": "ready"
          },
          {
            "effects": [
              {
                "set": {
                  "context": "project_id",
                  "value": null
                }
              }
            ],
            "from": "ready",
            "on": "message.selection.cleared",
            "to": "empty"
          }
        ]
      },
      "view_state": "empty"
