{
  "compositions": [
    {
      "child_state_machines": [
        {
          "context": {
            "selected_project_id": "$state_machine.selected_project_id",
            "workspace_id": "$state_machine.workspace_id"
          },
          "id": "list",
          "initial_view_state": "loading",
          "region": "nav",
          "state_machine": "state_machine.project.list"
        },
        {
          "context": {
            "project_id": "$state_machine.selected_project_id"
          },
          "id": "detail",
          "initial_view_state": "none",
          "region": "main",
          "selected": {
            "view_state": "loading",
            "when": {
              "context_present": "selected_project_id"
            }
          },
          "state_machine": "state_machine.project.detail"
        },
        {
          "context": {
            "project_id": "$state_machine.selected_project_id"
          },
          "id": "activity",
          "initial_view_state": "empty",
          "region": "aside",
          "selected": {
            "view_state": "ready",
            "when": {
              "context_present": "selected_project_id"
            }
          },
          "state_machine": "state_machine.project.activity"
        }
      ],
      "context": {
        "selected_project_id": {
          "primitive": "ID"
        },
        "workspace_id": {
          "primitive": "ID"
        }
      },
      "id": "state_machine.project.board.ready",
      "message_sync_rules": [
        {
          "do": [
            {
              "set": {
                "context": "selected_project_id",
                "from": "$message.project_id"
              }
            },
            {
              "send": {
                "instance": "detail",
                "message": "message.project.selection_changed",
                "payload_bindings": {
                  "project_id": "$message.project_id"
                }
              }
            },
            {
              "send": {
                "instance": "activity",
                "message": "message.project.selection_changed",
                "payload_bindings": {
                  "project_id": "$message.project_id"
                }
              }
            }
          ],
          "id": "select_project_updates_state_machines",
          "when": {
            "instance": "list",
            "message": "message.project.selected"
          }
        }
      ],
      "renderers": {
        "textual": {
          "layout": {
            "containers": {
              "aside": {
                "id": "aside",
                "kind": "Container",
                "order": 3,
                "required": true
              },
              "main": {
                "id": "main",
                "kind": "Container",
                "order": 2,
                "required": true
              },
              "nav": {
                "id": "nav",
                "kind": "Container",
                "order": 1,
                "required": true
              }
            },
            "screen_class": "ProjectBoardScreen"
          },
          "style": {
            "rules": [
              {
                "declarations": {
                  "layout": "horizontal"
                },
                "selector": "screen"
              },
              {
                "declarations": {
                  "width": "32"
                },
                "selector": "region.nav"
              },
              {
                "declarations": {
                  "width": "28"
                },
                "selector": "region.aside"
              }
            ]
          }
        },
        "web": {
          "layout": {
            "regions": {
              "aside": {
                "classes": [
                  "dispatch-board-aside"
                ],
                "element": "aside",
                "order": 3,
                "required": true,
                "role": "complementary"
              },
              "main": {
                "classes": [
                  "dispatch-board-main"
                ],
                "element": "main",
                "order": 2,
                "required": true,
                "role": "main"
              },
              "nav": {
                "classes": [
                  "dispatch-board-nav"
                ],
                "element": "nav",
                "order": 1,
                "required": true,
                "role": "navigation"
              }
            },
            "root": {
              "classes": [
                "dispatch-board"
              ],
              "element": "section",
              "role": "region"
            }
          },
          "style": {
            "rules": [
              {
                "declarations": {
                  "display": "grid",
                  "gap": "token.gap",
                  "grid-template-columns": "token.nav_width 1fr token.aside_width"
                },
                "selector": "root"
              },
              {
                "declarations": {
                  "min-width": "token.nav_width"
                },
                "selector": "region.nav"
              },
              {
                "declarations": {
                  "min-width": "0"
                },
                "selector": "region.main"
              },
              {
                "declarations": {
                  "min-width": "token.aside_width"
                },
                "selector": "region.aside"
              }
            ],
            "tokens": {
              "aside_width": "16rem",
              "gap": "1rem",
              "nav_width": "20rem"
            }
          }
        }
      },
      "state_machine": "state_machine.project.board",
      "view_state": "ready"
    }
  ],
