                      "from": "$outcome.result.message"
                    }
                  }
                }
              },
              "unauthenticated": {
                "no_local_effect": {
                  "rationale": "The response surface reports authentication failure without a local transition.",
                  "reason": "handled_by_response_surface"
                }
              },
              "unavailable": {
                "no_local_effect": {
                  "rationale": "The response surface reports temporary unavailability without a local transition.",
                  "reason": "handled_by_response_surface"
                }
              }
            }
          },
