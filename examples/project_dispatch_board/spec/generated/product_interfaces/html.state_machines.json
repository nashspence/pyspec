    {
      "data_loaders": {
        "read_activity": {
          "application_action": "application_action.project.read",
          "input_bindings": {
            "project_id": {
              "from": "$context.project_id"
            }
          },
          "load": {
            "on_enter": true
          },
          "outcome_effects": {
            "forbidden": {
              "no_local_effect": {
                "rationale": "The activity panel remains in its current state when authorization blocks the refresh.",
                "reason": "intentionally_unobservable"
              }
            },
            "found": {
              "no_local_effect": {
                "reason": "result_bound_without_signal"
              },
              "result_binding": {
                "data_key": "activity",
                "from": {
                  "from": "$outcome.result"
                }
              }
            },
            "not_found": {
              "no_local_effect": {
                "rationale": "The parent detail panel owns not-found display for the selected project.",
                "reason": "intentionally_unobservable"
              }
            },
            "unauthenticated": {
              "no_local_effect": {
                "rationale": "The entry response surface owns unauthenticated display.",
                "reason": "intentionally_unobservable"
              }
            }
          }
        }
      },
      "id": "state_machine.project.activity.ready",
