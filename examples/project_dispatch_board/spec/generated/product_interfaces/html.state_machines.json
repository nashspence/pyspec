            "application_action": "application_action.project.approve",
            "input_bindings": {
              "approved_by": {
                "from": "$actor.id"
              },
              "project_id": {
                "from": "$context.project_id"
              }
            },
            "outcome_effects": {
              "approved": {
                "raise": {
                  "data_refresh_signal": "project_changed"
                }
              },
              "forbidden": {
                "no_local_effect": {
                  "rationale": "The response surface keeps the detail panel unchanged for forbidden approval.",
                  "reason": "handled_by_response_surface"
                }
              },
              "not_found": {
                "no_local_effect": {
                  "rationale": "The response surface reports a missing project without a local transition.",
                  "reason": "handled_by_response_surface"
                }
              },
              "transition_not_allowed": {
                "raise": {
                  "local_signal": "show_transition_not_allowed",
