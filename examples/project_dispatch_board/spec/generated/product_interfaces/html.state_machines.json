        "action_bindings": {},
        "assets": [],
        "fields": [],
        "text": [
          "text.project.activity.empty.heading",
          "text.project.activity.empty.body"
        ]
      },
      "state_machine": {
        "context": {
          "additionalProperties": false,
          "properties": {
            "project_id": {
              "type": [
                "null",
                "string"
              ]
            }
          },
          "required": [],
          "type": "object"
        },
        "initial_view_state": "empty",
        "transitions": [
          {
            "from": "empty",
            "on": {
              "local_signal": "selection_changed"
            },
            "to": "ready"
          },
          {
            "effects": [
              {
                "set": {
                  "context": "project_id",
                  "value": null
                }
              }
            ],
            "from": "ready",
            "on": {
              "local_signal": "selection_cleared"
            },
            "to": "empty"
          }
        ]
      },
      "view_state": "empty"
